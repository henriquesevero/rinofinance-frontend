# Base URL of the RinoFinance API (rinofinance-api), no trailing slash.
# Local dev default matches the backend's default PORT (8080).
VITE_API_URL=http://localhost:8080

# logo.dev publishable token (safe to expose client-side), used to fetch
# brand logos for card purchases/subscriptions by domain (e.g.
# img.logo.dev/netflix.com?token=...). Get yours at https://logo.dev —
# Settings > API Keys > Publishable Key. Logos silently fall back to a
# generic icon if this is left blank.
VITE_LOGODEV_TOKEN=
